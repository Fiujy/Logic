# URL PostgreSQL (voir docker-compose.yml à la racine du repo).
# Exemple avec le service `postgres` du compose actuel (DB logic / user logic) :
# DATABASE_URL="postgresql://logic:logic@localhost:5432/logic?schema=public"

DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/DATABASE?schema=public"

# --- Option Prisma : URL prisma+postgres://... (Prisma Dev) ---
# Nécessite `npx prisma dev` pour que les ports internes répondent.
# Voir la doc Prisma : https://www.prisma.io/docs

# Après mise à jour du schéma / première install :
#   npm run db:setup
# (équivalent à db:push puis db:seed)
